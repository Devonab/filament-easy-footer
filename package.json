{
    "private": true,
    "type": "module",
    "scripts": {
        "dev:styles": "npx @tailwindcss/cli -i resources/css/index.css -o resources/dist/filament-easy-footer.css --postcss --watch",
        "dev:scripts": "node bin/build.js --dev",
        "build:styles": "npx @tailwindcss/cli -i resources/css/index.css -o resources/dist/filament-easy-footer.css --postcss --minify && npm run purge",
        "build:scripts": "node bin/build.js",
        "purge": "filament-purge -i resources/dist/filament-easy-footer.css -o resources/dist/filament-easy-footer.css -v 3.x",
        "dev": "npm-run-all --parallel dev:*",
        "build": "npm-run-all build:*"
    },
    "devDependencies": {
        "@awcodes/filament-plugin-purge": "^1.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.1.10",
        "@tailwindcss/typography": "^0.5.20",
        "esbuild": "^0.28.1",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.4.26",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.2"
    },
    "dependencies": {
        "@tailwindcss/cli": "^4.1.10"
    }
}
